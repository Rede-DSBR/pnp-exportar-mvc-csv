<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - pnp_exportar_mvc_csv</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/pnp_exportar_mvc_csv.styles.css" asp-append-version="true" />
      <link href="https://cdn.jsdelivr.net/npm/vuetify@2.x/dist/vuetify.min.css" rel="stylesheet">

       <link rel="stylesheet" href="~/css/multiselect.css" asp-append-version="true" /> 
   

</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
             <h1 class="display-7">Módulo de Exportação de Dados da PNP </h1>
             <p>
                 <div>DW Vendas
            <a href="/PnpQuery?Ano=2021&query=queryDW_VENDAS.dax&titulo=DW Vendas;Faturamento Loja" title="Faturamento Loja" >Faturamento Loja</a>
            
             </div>


            <div>Dados Acadêmicos
            <a href="/PnpQuery?Ano=2021&query=queryDadosGerais.dax&titulo=Dados Acadêmicos;Curso, matrícula e oferta" title="Curso, matrícula e oferta" >Curso, matrícula e oferta</a>
             <a href="/PnpQuery?Ano=2021&query=queryDadosGerais.dax&titulo=Dados Acadêmicos;Curso, matrícula e oferta" title="Curso, matrícula e oferta" >Curso, matrícula e oferta</a>

             <a href="/PnpQuery?Ano=2021&query=queryCassificacaoRacialRendaSexo.dax&titulo=Dados Acadêmicos;Classificação Racial, Renda, Sexo e Faixa Etária" title="Classificação Racial, Renda, Sexo e Faixa Etária" >Classificação Racial, Renda, Sexo e Faixa Etária</a>
             </div>
             </p>
             <div>Indicadores de Pessoal
              <a href="/PnpQuery?Ano=2021&query=queryTitulacaoDocente.dax&titulo=Indicadores de Pessoal;Titulação Docente" title="Titulação Docente" >Titulação Docente</a>
               <a href="/PnpQuery?Ano=2021&query=queryTecnicosAdmNivel.dax&titulo=Indicadores de Pessoal;Técnico Administrativo por Nível" title="Técnico Administrativo por Nível" > Técnico Administrativo por Nível</a>
              <a href="/PnpQuery?Ano=2021&query=queryProfessoresPorInstituicao.dax&titulo=Indicadores de Pessoal;Professores Por Instituição" title="Professores Por Instituição" > Professores Por Instituição</a>
               </div>
           
              <div>Indicadores Acadêmicos
              <a href="/PnpQuery?Ano=2021&query=queryTaxaEvasao.dax&titulo=Indicadores de Acadêmicos;Taxa de Evasão" title="Taxa de Evasão" >Taxa de Evasão</a>
              <a href="/PnpQuery?Ano=2021&query=queryEficienciaAcademica.dax&titulo=Indicadores de Acadêmicos;Eficiência Acadêmica" title="Eficiência Acadêmica" >Eficiência Acadêmica</a>
               <a href="/PnpQuery?Ano=2021&query=queryRelacaoAlunoProfessorRAP.dax&titulo=Indicadores de Acadêmicos;Relação Aluno Professsor (RAP)" title="Relação Aluno Professsor (RAP)" >Relação Aluno Professsor (RAP)</a>
               <a href="/PnpQuery?Ano=2021&query=queryIndiceVerticalizacao.dax&titulo=Indicadores de Acadêmicos;Índice de Verticalização" title="Índice de Verticalização" >Índice de Verticalização</a>
               <a href="/PnpQuery?Ano=2021&query=queryTaxaOcupacao.dax&titulo=Indicadores de Acadêmicos;Taxa de Ocupação" title="Taxa de Ocupação" >Taxa de Ocupação</a>

                 <div>Percentuais Legais
              <a href="/PnpQuery?Ano=2021&query=queryPercentuaisLegais.dax&titulo=Percentuais Legais;Percentuais Legais" title="Percentuais Legais" >Percentuais Legais</a>
              <a href="/PnpQuery?Ano=2021&query=queryReservaVagas.dax&titulo=Percentuais Legais;Reserva de Vagas" title="Reserva de Vagas" >Reserva de Vagas</a>
               <a href="/PnpQuery?Ano=2021&query=queryOfertaVagasNoturnas.dax&titulo=Percentuais Legais;Oferta de Vagas Noturnas" title="Oferta de Vagas Noturnas" >Oferta de Vagas Noturnas</a>
             <a href="/PnpQuery?Ano=2021&query=queryRelacaoInscritosVagas.dax&titulo=Percentuais Legais;Relação Inscritos/Vagas" title="Relação Inscritos/Vagas" >Relação Inscritos/Vagas</a>
               </div>   
            <div>Dados INEP
              <a href="/PnpQuery?Ano=2021&query=queryIGC.dax&titulo=Dados INEP;Índice Geral de Cursos" title="Índice Geral de Cursos" >Índice Geral de Cursos</a>
                <a href="/PnpQuery?Ano=2021&query=queryCPC.dax&titulo=Dados INEP;Conceito preliminar de curso" title="Conceito preliminar de curso" >Conceito preliminar de curso</a>


               conceito preliminar de curso
            
               </div>   
            <div class="container-fluid">
                 <div class="navbar-collapse collapse  justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            
                        </li>
                        <Br></Br>
                        <li class="nav-item">
                            
                           
                        </li>
                    </ul>
                </div>
               
                
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                 
                 
                    
                           <img src="~/images/pnp.png" width="225px" height="150px" class="center">
                           
                      
                    
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2022 - Pnp_exportar_mvc_csv  
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
      <script src="~/js/multiselect.min.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
